# .env.example — committed placeholder. Copy to .env and fill in your values.
# Never commit .env — it's in .gitignore.

# ComfyUI Cloud API key. Required for the `generation` tool to submit workflows.
# Generate at https://platform.comfy.org (API keys section).
COMFYUI_API_KEY=your-comfy-api-key-here

# ComfyUI Cloud API base URL. Default is https://cloud.comfy.org — the canonical
# cloud endpoint per docs.comfy.org/development/cloud/overview. Override for
# staging or a local ComfyUI instance if needed.
# Locked by Phase 7 (Endpoint Reconciliation, 2026-04-24) — see .planning/phases/07-comfyui-endpoint-reconciliation/07-VERIFICATION.md §3 Rotation Procedure
COMFYUI_API_BASE=https://cloud.comfy.org

# Optional: comma-separated list of additional hosts allowed as 302 redirect
# targets for signed URLs. Defaults cover cloud.comfy.org, googleapis.com,
# amazonaws.com, r2.cloudflarestorage.com. Override only if your tenant uses
# a different storage host.
# COMFYUI_ALLOWED_REDIRECT_HOSTS=

# Optional: comma-separated list of browser origins allowed to POST to
# /mcp when the HTTP transport is enabled (--http). Non-browser MCP clients
# (Claude Desktop, Cursor, CLI) do NOT send an Origin header and are always
# allowed; this guard only fires for browser tabs (SEC-03). Example:
# HTTP_ALLOWED_ORIGINS=http://localhost:5173,https://dashboard.example.com
# HTTP_ALLOWED_ORIGINS=
